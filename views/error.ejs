<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
            background: #f7f0f3;
            line-height: 1.6;
            color: #2b2b2b;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .error-box {
            background: #ffffff;
            border-left: 6px solid #c41e3a;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
            text-align: center;
        }
        .error-code {
            font-size: 3em;
            color: #c41e3a;
            font-weight: 700;
            margin-bottom: 20px;
        }
        h1 {
            font-family: 'Lucida Calligraphy', 'Segoe Script', 'Brush Script MT', cursive;
            color: #2b2b2b;
            margin-bottom: 15px;
            font-size: 1.8em;
        }
        .error-message {
            color: #666;
            font-size: 1.1em;
            margin-bottom: 30px;
            word-break: break-word;
        }
        .error-details {
            background: #f5f0f3;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 30px;
            font-family: 'Courier New', monospace;
            font-size: 0.9em;
            color: #555;
            text-align: left;
            max-height: 200px;
            overflow-y: auto;
        }
        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
        }
        a {
            display: inline-block;
            padding: 12px 25px;
            background: #9b6b7c;
            color: #fff;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            transition: background 0.3s ease;
        }
        a:hover {
            background: #7a5461;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="error-box">
            <div class="error-code"><%= status || 500 %></div>
            <h1>Oops! Something Went Wrong</h1>
            <p class="error-message"><%= message || 'An unexpected error occurred' %></p>
            <% if (details) { %>
                <div class="error-details"><%= details %></div>
            <% } %>
            <div class="button-group">
                <a href="/">Go to Home</a>
                <a href="javascript:history.back()">Go Back</a>
            </div>
        </div>
    </div>
</body>
</html>
