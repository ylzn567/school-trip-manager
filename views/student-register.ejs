<!DOCTYPE html>
<html lang="he">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>הרשמת תלמידה</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            padding: 20px 0;
            direction: rtl;
            font-family: 'Open Sans', sans-serif;
            color: #222222;
            margin: 0;
        }

        .card {
            border: 1px solid #dee2e6;
            border-radius: 12px;
            background: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .card-header {
            background: transparent;
            border-bottom: none;
            padding-bottom: 0;
        }

        .card-header h1 {
            font-size: 1.8rem;
            font-weight: 600;
            color: #2c3e50;
            margin: 0;
        }

        .form-control {
            border-radius: 8px;
            border: 1px solid #bdc3c7;
            padding: 12px 14px;
            font-size: 0.98rem;
            transition: border-color 0.3s ease;
        }

        .form-control:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);
        }

        .btn-success {
            background: #27ae60;
            border: none;
            border-radius: 8px;
            padding: 12px 18px;
            font-size: 1rem;
            font-weight: 600;
            color: #ffffff;
            transition: background-color 0.3s ease;
        }

        .btn-success:hover {
            background: #229954;
        }

        .back-link {
            text-align: center;
            margin-top: 18px;
        }

        .back-link a {
            color: #3498db;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
        }

        .back-link a:hover {
            text-decoration: underline;
        }

        .alert {
            border-radius: 8px;
            border: 1px solid #e74c3c;
            background: #fdf2f2;
            color: #c0392b;
        }
    </style>


        .container {
            max-width: 520px;
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header text-white text-center">
                        <h3 class="mb-0"> הרשמה של תלמידה</h3>
                    </div>
                    <div class="card-body p-4">
                        <% if (error) { %>
                            <div class="alert alert-<%= error.includes('בהצלחה') ? 'success' : 'danger' %>" role="alert">
                                <%= error %>
                            </div>
                        <% } %>
                        
                        <form action="/register-student" method="POST" class="needs-validation">
                            <div class="mb-3">
                                <label for="firstName" class="form-label">שם פרטי *</label>
                                <input type="text" class="form-control" id="firstName" name="firstName" required>
                            </div>

                            <div class="mb-3">
                                <label for="lastName" class="form-label">שם משפחה *</label>
                                <input type="text" class="form-control" id="lastName" name="lastName" required>
                            </div>

                            <div class="mb-3">
                                <label for="idNumber" class="form-label">מספר תעודת זהות *</label>
                                <input type="text" class="form-control" id="idNumber" name="idNumber" required>
                            </div>

                            <div class="mb-3">
                                <label for="className" class="form-label">כיתה *</label>
                                <input type="text" class="form-control" id="className" name="className" placeholder="לדוגמה: א1, ב2, ג1" required>
                            </div>

                            <button type="submit" class="btn btn-success w-100 btn-lg">הרשמה</button>
                        </form>

                        <p class="text-center mt-3">
                            <a href="/" class="text-decoration-none">חזרה לדף הבית</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
