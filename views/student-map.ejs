<!DOCTYPE html>
<html lang="he">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>מפת מיקום תלמידות</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <style>
        body {
            background-color: #f8f9fa;
            direction: rtl;
            font-family: 'Open Sans', sans-serif;
            color: #212121;
            margin: 0;
            padding: 0;
        }

        .container-lg {
            max-width: 1100px;
            margin: 0 auto;
            padding: 18px 16px;
        }

        header {
            border-bottom: 1px solid #dee2e6;
            padding-bottom: 16px;
            margin-bottom: 22px;
        }

        header h1 {
            font-size: 2rem;
            margin: 0;
            font-weight: 600;
            color: #2c3e50;
        }

        header p {
            margin: 8px 0 0;
            color: #7f8c8d;
        }

        #map {
            width: 100%;
            min-height: 640px;
            border: 1px solid #dee2e6;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .summary-card {
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 12px;
            padding: 18px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .summary-card h2 {
            font-size: 1rem;
            margin: 0 0 14px;
            color: #34495e;
            font-weight: 600;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid #ecf0f1;
        }

        .summary-item:last-child {
            border-bottom: none;
        }

        .refresh-button {
            background: #3498db;
            border: none;
            color: #ffffff;
            font-size: 0.96rem;
            padding: 10px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: background-color 0.3s ease;
        }

        .refresh-button:hover {
            background: #2980b9;
        }

        .warning {
            color: #e74c3c;
            font-weight: 700;
        }

        .link-button {
            display: inline-block;
            text-decoration: none;
            color: #3498db;
            border: 1px solid #3498db;
            padding: 10px 14px;
            border-radius: 8px;
            background: #ffffff;
            font-weight: 600;
            transition: background-color 0.3s ease;
        }

        .link-button:hover {
            background: #ecf0f1;
        }
    </style>
</head>

<body>
    <%- include('partials/nav') %>

        <div class="container-lg mt-4">
            <div class="hero-section">
                <h1>מפת מיקום תלמידות</h1>
                <p>מעקב מיקום בזמן אמת של תלמידות ומורה.</p>
            </div>

            <div class="row">
                <div class="col-lg-8 mb-4">
                    <div id="map"></div>
                </div>
                <div class="col-lg-4">
                    <div class="summary-card">
                        <h2>סטטוס מיקום</h2>
                        <div class="summary-item">
                            <span>מספר תלמידות פעילות:</span>
                            <strong id="student-count">0</strong>
                        </div>
                        <div class="summary-item">
                            <span>מספר מורות פעילות:</span>
                            <strong id="teacher-count">0</strong>
                        </div>
                        <div class="summary-item">
                            <span>עדכון אחרון:</span>
                            <strong id="last-updated">טוען...</strong>
                        </div>
                        <div class="summary-item">
                            <span>סטטוס חיבור:</span>
                            <strong id="connection-status">...מחכה</strong>
                        </div>
                        <div class="summary-item" id="distance-warning"
                            style="display:none; color:#d9534f; font-weight:700;">
                            <span>אזהרה:</span>
                            <strong id="warning-text">אין תלמידות רחוקות</strong>
                        </div>
                        <button id="refreshButton" class="refresh-button mt-3">טען מיקומים עכשיו</button>
                    </div>
                    
                </div>
            </div>

            <div class="row mb-5">
                <div class="col-12 text-end">
                    <a href="/" class="btn btn-primary">חזרה לדף הבית</a>
                </div>
            </div>
        </div>

        <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
        <script>
            const map = L.map('map').setView([32.0853, 34.7818], 11);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const routes = [
                [ // תלמידה 1 - נשארת קרובה
                    [32.0840, 34.7800], [32.0855, 34.7830], [32.0870, 34.7860],
                    [32.0890, 34.7890], [32.0905, 34.7870], [32.0915, 34.7840],
                    [32.0925, 34.7810], [32.0910, 34.7770], [32.0890, 34.7740], [32.0860, 34.7730]
                ],
                [ // תלמידה 2 - נשארת קרובה
                    [32.0735, 34.7680], [32.0750, 34.7715], [32.0770, 34.7740],
                    [32.0790, 34.7765], [32.0810, 34.7785], [32.0830, 34.7795],
                    [32.0850, 34.7805], [32.0870, 34.7815], [32.0885, 34.7830], [32.0900, 34.7850]
                ],
                [ // תלמידה 3 - מתרחקת מעל 3 ק"מ!
                    [32.0760, 34.7860], // קרובה
                    [32.0850, 34.7860], // קרובה
                    [32.0950, 34.7860], // מתחילה להתרחק
                    [32.1050, 34.7860], // מתקרבת לגבול
                    [32.1150, 34.7860], // חצתה את ה-3 ק"מ! (התראה תקפוץ)
                    [32.1250, 34.7860], // רחוקה מאוד (כ-4.5 ק"מ)
                    [32.1200, 34.7860], // מתחילה לחזור
                    [32.1100, 34.7860], // עדיין רחוקה
                    [32.0900, 34.7860], // חזרה לאזור הבטוח
                    [32.0800, 34.7860]  // קרובה
                ]
            ];

            const teacherRoute = [
                [32.0890, 34.7890], [32.0880, 34.7870], [32.0870, 34.7850],
                [32.0860, 34.7830], [32.0850, 34.7810], [32.0835, 34.7795],
                [32.0820, 34.7780], [32.0810, 34.7765], [32.0800, 34.7750],
                [32.0785, 34.7735]
            ];

            const markers = {};
            const teacherRangeCircles = [];
            const studentCountLabel = document.getElementById('student-count');
            const teacherCountLabel = document.getElementById('teacher-count');
            const lastUpdatedLabel = document.getElementById('last-updated');
            const connectionStatusLabel = document.getElementById('connection-status');
            const warningRow = document.getElementById('distance-warning');
            const warningText = document.getElementById('warning-text');
            const refreshButton = document.getElementById('refreshButton');

            // מנגנון זכרון לכתובות כדי לא להעמיס על השרת
            const addressCache = {};

            const getStreetName = async (lat, lon) => {
                // מעגלים מעט את הקואורדינטות כדי לחסוך קריאות כפולות בדיוק על אותו אזור
                const key = `${lat.toFixed(4)},${lon.toFixed(4)}`;
                if (addressCache[key]) return addressCache[key];

                try {
                    // פנייה לשירות המפות החינמי לבקשת הכתובת
                    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=18&addressdetails=1`, {
                        headers: { 'Accept-Language': 'he' } // מבקשים את הכתובת בעברית!
                    });
                    const data = await response.json();

                    // שולפים את שם הרחוב, ואם אין - את שם השכונה או העיר
                    const street = data.address?.road || data.address?.neighbourhood || data.address?.city || "מיקום כללי";
                    addressCache[key] = street;
                    return street;
                } catch (error) {
                    return "מיקום לא ידוע";
                }
            };

            const formatDate = (value) => {
                const date = new Date(value);
                return isNaN(date.getTime()) ? 'לא זמין' : date.toLocaleString('he-IL');
            };

            const buildStudentPopup = (location) => {
                return `
        <div style="direction: rtl; text-align: right;">
            <strong>תלמידה:</strong> ${location.entity.firstName} ${location.entity.lastName}<br>
            <strong>ת.ז.:</strong> ${location.entity.idNumber}<br>
            <strong>כיתה:</strong> ${location.entity.className}<br>
            <strong>מרחק מהמורה:</strong> ${location.minDistance ? location.minDistance.toFixed(2) + ' ק"מ' : 'לא ידוע'}<br>
            <strong>עדכון:</strong> ${formatDate(location.reportedAt)}
        </div>`;
            };

            const buildTeacherPopup = (location) => {
                return `
        <div style="direction: rtl; text-align: right;">
            <strong>מורה:</strong> ${location.entity.firstName} ${location.entity.lastName}<br>
            <strong>ת.ז.:</strong> ${location.entity.idNumber}<br>
            <strong>כיתה:</strong> ${location.entity.className}<br>
            <strong>עדכון:</strong> ${formatDate(location.reportedAt)}
        </div>`;
            };

            const getRoutePoint = (route, offset) => {
                const step = Math.floor(Date.now() / 5000) + offset;
                return route[step % route.length];
            };

            const createMarker = (location, isFar = false) => {
                const latLng = [location.latitude, location.longitude];
                if (location.type === 'teacher') {
                    return L.circleMarker(latLng, {
                        radius: 12,
                        color: '#d9534f',
                        fillColor: '#d9534f',
                        fillOpacity: 0.95,
                        weight: 4
                    }).bindPopup(buildTeacherPopup(location));
                }

                return L.circleMarker(latLng, {
                    radius: 9,
                    color: isFar ? '#c9302c' : '#337ab7',
                    fillColor: isFar ? '#c9302c' : '#337ab7',
                    fillOpacity: 0.85,
                    weight: 3
                }).bindPopup(buildStudentPopup(location));
            };

            const haversineKm = (lat1, lon1, lat2, lon2) => {
                const toRad = (deg) => deg * Math.PI / 180;
                const R = 6371; // רדיוס כדור הארץ בקילומטרים
                const dLat = toRad(lat2 - lat1);
                const dLon = toRad(lon2 - lon1);
                const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
                return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            };

            const clearTeacherCircles = () => {
                teacherRangeCircles.forEach(circle => map.removeLayer(circle));
                teacherRangeCircles.length = 0;
            };

            const updateMap = async () => {
                try {
                    connectionStatusLabel.textContent = 'טוען...';
                    const [studentsResponse, teachersResponse] = await Promise.all([
                        fetch('/api/students'),
                        fetch('/api/teachers')
                    ]);

                    if (!studentsResponse.ok || !teachersResponse.ok) {
                        throw new Error('שגיאה בטעינת נתוני המסד');
                    }

                    const students = await studentsResponse.json();
                    const teachers = await teachersResponse.json();
                    const locations = [];

                    students.forEach((student, index) => {
                        const route = routes[index % routes.length];
                        const [latitude, longitude] = getRoutePoint(route, index);
                        locations.push({
                            type: 'student',
                            entity: student,
                            latitude,
                            longitude,
                            reportedAt: new Date().toISOString()
                        });
                    });

                    teachers.forEach((teacher, index) => {
                        const [latitude, longitude] = getRoutePoint(teacherRoute, index + 1);
                        locations.push({
                            type: 'teacher',
                            entity: teacher,
                            latitude,
                            longitude,
                            reportedAt: new Date().toISOString()
                        });
                    });

                    studentCountLabel.textContent = students.length;
                    teacherCountLabel.textContent = teachers.length;
                    lastUpdatedLabel.textContent = formatDate(new Date());
                    connectionStatusLabel.textContent = 'מחובר';

                    const teacherLocations = locations.filter(loc => loc.type === 'teacher');

                    const studentLocations = locations.filter(loc => loc.type === 'student');

                    const farStudents = studentLocations.filter(student => {
                        if (teacherLocations.length === 0) {
                            return false;
                        }
                        const minDistance = Math.min(...teacherLocations.map(teacher =>
                            haversineKm(student.latitude, student.longitude, teacher.latitude, teacher.longitude)
                        ));
                        student.minDistance = minDistance;

                        // שינוי ל-3 קילומטר (היה 2)
                        return minDistance > 3;
                    });

                    // טיפול בהצגת שמות התלמידות והכתובת שלהן
                    if (farStudents.length > 0) {
                        warningRow.style.display = 'flex';

                        // יצירת משפט אישי לכל תלמידה שמתרחקת
                        const warningMessages = await Promise.all(farStudents.map(async (student) => {
                            const streetName = await getStreetName(student.latitude, student.longitude);
                            return ` <strong>${student.entity.firstName}</strong> התרחקה יותר מ-3 ק"מ! היא נמצאת באזור <strong>${streetName}</strong>.`;
                        }));

                        // אם יש כמה תלמידות רחוקות, נציג כל אחת בשורה נפרדת
                        warningText.innerHTML = warningMessages.join('<br><br>');
                    } else {
                        warningRow.style.display = 'none';
                        warningText.innerHTML = 'אין תלמידות רחוקות יותר מ-3 ק"מ';
                    }

                    const idsSeen = new Set();
                    locations.forEach(location => {
                        const markerId = `${location.type}-${location.entity.idNumber}`;
                        idsSeen.add(markerId);

                        // שינוי הצבע לאדום רק אם המרחק גדול מ-3
                        const isFar = location.type === 'student' && location.minDistance > 3;

                        if (markers[markerId]) {
                            markers[markerId].setLatLng([location.latitude, location.longitude]);
                            // עדכון הפופאפ כדי שיציג את המרחק החדש בכל קפיצה
                            markers[markerId].setPopupContent(
                                location.type === 'teacher' ? buildTeacherPopup(location) : buildStudentPopup(location)
                            );

                            // שינוי צבע הסמן אם היא מתרחקת
                            if (location.type === 'student') {
                                markers[markerId].setStyle({
                                    color: isFar ? '#c9302c' : '#337ab7',
                                    fillColor: isFar ? '#c9302c' : '#337ab7'
                                });
                            }
                        } else {
                            markers[markerId] = createMarker(location, isFar).addTo(map);
                        }
                    });

                    Object.keys(markers).forEach(key => {
                        if (!idsSeen.has(key)) {
                            map.removeLayer(markers[key]);
                            delete markers[key];
                        }
                    });

                    const allMarkers = Object.values(markers);
                    if (allMarkers.length > 0) {
                        // הוספתי אנימציה חלקה לזום
                        const group = L.featureGroup(allMarkers);
                        map.fitBounds(group.getBounds(), { padding: [40, 40], maxZoom: 14, animate: true, duration: 1 });
                    }
                } catch (err) {
                    connectionStatusLabel.textContent = 'שגיאה';
                    console.error(err);
                }
            };

            refreshButton.addEventListener('click', updateMap);
            updateMap();
            setInterval(updateMap, 5000);
        </script>
</body>

</html>