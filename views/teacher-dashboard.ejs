<!DOCTYPE html>
<html lang="he">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>לוח בקרה - מורה</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            direction: rtl;
            font-family: 'Open Sans', sans-serif;
            color: #222222;
            margin: 0;
        }

        .dashboard-header {
            background: transparent;
            color: #2c3e50;
            padding: 24px 0;
            margin-bottom: 24px;
            border-bottom: 1px solid #dee2e6;
        }

        .dashboard-header h1 {
            font-size: 2rem;
            font-weight: 600;
            margin: 0;
        }

        .teacher-info {
            background: #ffffff;
            padding: 20px;
            border: 1px solid #dee2e6;
            border-radius: 12px;
            margin-bottom: 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .teacher-info h3 {
            color: #34495e;
            margin-bottom: 16px;
            font-size: 1rem;
            font-weight: 600;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #ecf0f1;
        }

        .info-item:last-child {
            border-bottom: none;
        }

        .info-label {
            font-weight: 600;
            color: #7f8c8d;
        }

        .info-value {
            color: #2c3e50;
        }

        .students-section h2 {
            color: #34495e;
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 18px;
        }

        .student-card {
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .student-card h4 {
            color: #2c3e50;
            font-size: 1.1rem;
            font-weight: 600;
            margin: 0 0 8px;
        }

        .student-details {
            color: #7f8c8d;
            font-size: 0.9rem;
        }

        .logout-btn {
            background: #e74c3c;
            border: none;
            color: #ffffff;
            padding: 10px 16px;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: background-color 0.3s ease;
        }

        .logout-btn:hover {
            background: #c0392b;
            color: #ffffff;
        }

        .map-link {
            background: #3498db;
            border: none;
            color: #ffffff;
            padding: 10px 16px;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: background-color 0.3s ease;
        }

        .map-link:hover {
            background: #2980b9;
            color: #ffffff;
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="container-lg mt-5">
        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1> ברוכה הבאה, <%= teacher.firstName %> <%= teacher.lastName %></h1>
            <p class="mb-0">לוח בקרה של מורה</p>
        </div>

        <!-- Teacher Info -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="teacher-info">
                    <h3> פרטי המורה</h3>
                    <div class="info-item">
                        <span class="info-label">שם מלא:</span>
                        <span class="info-value"><%= teacher.firstName %> <%= teacher.lastName %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">תעודת זהות:</span>
                        <span class="info-value"><%= teacher.idNumber %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">כיתה:</span>
                        <span class="info-value badge bg-primary" style="font-size: 0.95rem;"><%= teacher.className %></span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="teacher-info">
                    <h3> סטטיסטיקה</h3>
                    <div class="info-item">
                        <span class="info-label">מספר תלמידות בכיתה:</span>
                        <span class="info-value badge bg-success" style="font-size: 1rem;"><%= students.length %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">תאריך הרשמה:</span>
                        <span class="info-value"><%= new Date(teacher.createdAt).toLocaleDateString('he-IL') %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Students List -->
        <div class="students-section">
            <h2> תלמידות בכיתה <%= teacher.className %></h2>
            
            <% if (students.length === 0) { %>
                <div class="empty-state">
                    <p>אין תלמידות רשומות בכיתה זו עדיין</p>
                </div>
            <% } else { %>
                <ul class="list-group">
                    <% students.forEach(student => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong> <%= student.firstName %> <%= student.lastName %></strong><br>
                                <small>ת.ז: <%= student.idNumber %></small>
                            </div>
                            <span class="badge bg-primary rounded-pill"><%= student.className %></span>
                        </li>
                    <% }); %>
                </ul>
            <% } %>
        </div>

        <!-- Action Buttons -->
        <div class="row mt-5 mb-5">
            <div class="col-md-6 mb-3">
                <a href="/student-map" class="btn btn-home btn-lg w-100">צפה במפת מיקום תלמידות</a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/" class="btn btn-home btn-lg w-100">חזרה לדף הבית</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
