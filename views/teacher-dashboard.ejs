<!DOCTYPE html>
<html lang="he">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>לוח בקרה - מורה</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            direction: rtl;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .dashboard-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 20px;
            margin-bottom: 40px;
            border-radius: 10px;
        }
        
        .teacher-info {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }
        
        .teacher-info h3 {
            color: #667eea;
            margin-bottom: 15px;
        }
        
        .info-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #eee;
        }
        
        .info-item:last-child {
            border-bottom: none;
        }
        
        .info-label {
            font-weight: bold;
            color: #666;
        }
        
        .info-value {
            color: #333;
        }
        
        .students-section h2 {
            color: #333;
            margin-bottom: 25px;
            padding-bottom: 10px;
            border-bottom: 3px solid #667eea;
        }
        
        .student-card {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            margin-bottom: 15px;
            border-right: 5px solid #667eea;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .student-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }
        
        .student-name {
            font-size: 1.2rem;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
        }
        
        .student-detail {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            color: #666;
            font-size: 0.95rem;
        }
        
        .empty-state {
            text-align: center;
            padding: 40px;
            color: #999;
            background: white;
            border-radius: 10px;
        }
        
        .btn-home {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            color: white;
        }
        
        .btn-home:hover {
            background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.35);
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="container-lg mt-5">
        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1>👋 ברוכה הבאה, <%= teacher.firstName %> <%= teacher.lastName %></h1>
            <p class="mb-0">לוח בקרה של מורה</p>
        </div>

        <!-- Teacher Info -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="teacher-info">
                    <h3>📋 פרטי המורה</h3>
                    <div class="info-item">
                        <span class="info-label">שם מלא:</span>
                        <span class="info-value"><%= teacher.firstName %> <%= teacher.lastName %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">תעודת זהות:</span>
                        <span class="info-value"><%= teacher.idNumber %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">כיתה:</span>
                        <span class="info-value badge bg-primary" style="font-size: 0.95rem;"><%= teacher.className %></span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="teacher-info">
                    <h3>📊 סטטיסטיקה</h3>
                    <div class="info-item">
                        <span class="info-label">מספר תלמידות בכיתה:</span>
                        <span class="info-value badge bg-success" style="font-size: 1rem;"><%= students.length %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">תאריך הרשמה:</span>
                        <span class="info-value"><%= new Date(teacher.createdAt).toLocaleDateString('he-IL') %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Students List -->
        <div class="students-section">
            <h2>🎓 תלמידות בכיתה <%= teacher.className %></h2>
            
            <% if (students.length === 0) { %>
                <div class="empty-state">
                    <p>אין תלמידות רשומות בכיתה זו עדיין</p>
                </div>
            <% } else { %>
                <div class="row">
                    <% students.forEach(student => { %>
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="student-card">
                                <div class="student-name">🎓 <%= student.firstName %> <%= student.lastName %></div>
                                <div class="student-detail">
                                    <strong>תעודת זהות:</strong>
                                    <span><%= student.idNumber %></span>
                                </div>
                                <div class="student-detail">
                                    <strong>כיתה:</strong>
                                    <span><%= student.className %></span>
                                </div>
                                <div class="student-detail">
                                    <strong>הרשמה:</strong>
                                    <span><%= new Date(student.createdAt).toLocaleDateString('he-IL') %></span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>

        <!-- Action Buttons -->
        <div class="row mt-5 mb-5">
            <div class="col-md-6 mb-3">
                <a href="/student-map" class="btn btn-home btn-lg w-100">צפה במפת מיקום תלמידות</a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/" class="btn btn-home btn-lg w-100">חזרה לדף הבית</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
